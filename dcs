   NAVBAR
   ============================================================ */
.nav {
  position: sticky; top: 0; z-index: 50;
  background: rgba(251, 252, 254, 0.86);
  backdrop-filter: saturate(180%) blur(12px);
  border-bottom: 1px solid var(--gray-200);
}
.nav__inner {
  max-width: var(--maxw); margin: 0 auto; padding: 16px 28px;
  display: flex; align-items: center; justify-content: space-between;
}
.brand { display: flex; align-items: center; gap: 12px; }
.brand__mark {
  width: 38px; height: 38px; border-radius: 9px;
  background: linear-gradient(150deg, var(--navy-700), var(--navy-900));
  display: grid; place-items: center;
  color: var(--gold-400); font-family: var(--display); font-weight: 600; font-size: 18px;
  box-shadow: var(--sh-sm);
}
.brand__name { font-family: var(--display); font-weight: 600; font-size: 17px; color: var(--navy-900); line-height: 1.1; }
.brand__sub { font-size: 11px; color: var(--gray-500); letter-spacing: 0.04em; text-transform: uppercase; }
.nav__links { display: flex; align-items: center; gap: 28px; }
.nav__links a { font-size: 14.5px; color: var(--gray-700); font-weight: 500; transition: color .18s; }
.nav__links a:hover, .nav__links a.is-active { color: var(--navy-700); }
.nav__links a.btn--primary { color: var(--white); }
.nav__links a.btn--primary:hover { color: var(--white); }
.nav__toggle { display: none; background: none; border: 0; padding: 6px; }
.nav__toggle span { display: block; width: 22px; height: 2px; background: var(--navy-800); margin: 4px 0; border-radius: 2px; }

/* ============================================================
   BOTÕES
   ============================================================ */
.btn {
  display: inline-flex; align-items: center; gap: 9px;
  padding: 13px 24px; border-radius: 10px; border: 1px solid transparent;
  font-size: 15px; font-weight: 600; letter-spacing: 0.01em;
  transition: transform .15s, box-shadow .2s, background .2s, color .2s, border-color .2s;
  text-decoration: none;
}
.btn:active { transform: translateY(1px); }
.btn--primary { background: var(--navy-700); color: var(--white); box-shadow: var(--sh-sm); }
.btn--primary:hover { background: var(--navy-800); box-shadow: var(--sh-md); }
.btn--gold { background: var(--gold-500); color: var(--navy-900); }
.btn--gold:hover { background: var(--gold-400); }
.btn--ghost { background: transparent; color: var(--navy-700); border-color: var(--gray-300); }
.btn--ghost:hover { border-color: var(--navy-500); background: var(--white); }
.btn--light { background: var(--white); color: var(--navy-800); }
.btn--light:hover { background: var(--gray-100); }
.btn--block { width: 100%; justify-content: center; }
.btn:disabled { opacity: .5; cursor: not-allowed; }
.btn .ico { width: 18px; height: 18px; }

/* ============================================================
   HERO (index)
   ============================================================ */
.hero {
  position: relative; overflow: hidden;
  background:
    radial-gradient(1100px 520px at 78% -8%, rgba(201,162,75,0.16), transparent 60%),
    linear-gradient(160deg, var(--navy-900) 0%, var(--navy-800) 52%, var(--navy-700) 100%);
  color: #EAF0F8;
}
.hero__grid { position:absolute; inset:0; opacity:.5;
  background-image: linear-gradient(rgba(255,255,255,.04) 1px, transparent 1px),
                    linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px);
  background-size: 54px 54px; mask-image: radial-gradient(80% 60% at 50% 30%, #000, transparent);
}
.hero__inner { position: relative; max-width: var(--maxw); margin: 0 auto; padding: 96px 28px 104px; }
.hero__layout { display: grid; grid-template-columns: 1.15fr 0.85fr; gap: 56px; align-items: center; }
.hero h1 { color: var(--white); font-size: clamp(38px, 5.4vw, 62px); font-weight: 600; letter-spacing: -0.02em; }
.hero h1 em { font-style: italic; color: var(--gold-400); }
.hero__lead { font-size: 18.5px; color: #C3D0E2; max-width: 540px; margin: 22px 0 34px; line-height: 1.65; }
.hero__cta { display: flex; gap: 14px; flex-wrap: wrap; }
.hero__note { margin-top: 22px; font-size: 13px; color: #8FA2BD; display: flex; align-items: center; gap: 8px; }

/* Painel "gauge" do hero — elemento de assinatura */
.hero__panel {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 18px; padding: 30px;
  backdrop-filter: blur(6px);
  box-shadow: 0 30px 60px rgba(0,0,0,.35);
}
.hero__panel h3 { color: var(--white); font-size: 16px; margin-bottom: 4px; }
.hero__panel p { color: #9FB1CC; font-size: 13px; margin: 0 0 20px; }
.gaugewrap { display: grid; place-items: center; margin: 8px 0 18px; }
.pillarbars { display: grid; gap: 11px; }
.pillarbar__row { display: grid; grid-template-columns: 96px 1fr 34px; align-items: center; gap: 12px; font-size: 12.5px; }
.pillarbar__name { color: #C3D0E2; }
.pillarbar__track { height: 7px; background: rgba(255,255,255,.1); border-radius: 99px; overflow: hidden; }
.pillarbar__fill { height: 100%; background: linear-gradient(90deg, var(--navy-500), var(--gold-400)); border-radius: 99px; }
.pillarbar__val { color: var(--gold-400); font-family: var(--mono); text-align: right; }

/* Faixa de credenciais */
.stripe { background: var(--white); border-bottom: 1px solid var(--gray-200); }
.stripe__inner { max-width: var(--maxw); margin: 0 auto; padding: 26px 28px; display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
.stat__num { font-family: var(--display); font-size: 30px; color: var(--navy-800); font-weight: 600; }
.stat__lbl { font-size: 13px; color: var(--gray-500); margin-top: 2px; }

/* ============================================================
   SEÇÕES INSTITUCIONAIS
   ============================================================ */
.section { padding: 84px 0; }
.section--tint { background: var(--gray-100); border-top: 1px solid var(--gray-200); border-bottom: 1px solid var(--gray-200); }
.section__head { max-width: 680px; margin-bottom: 46px; }
.section__head h2 { font-size: clamp(28px, 3.4vw, 40px); }
.section__head p { color: var(--gray-700); font-size: 17px; margin-top: 14px; }

.grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
.grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: 22px; }

.card {
  background: var(--white); border: 1px solid var(--gray-200);
  border-radius: var(--radius); padding: 28px; box-shadow: var(--sh-sm);
  transition: transform .2s, box-shadow .2s, border-color .2s;
}
.card--hover:hover { transform: translateY(-3px); box-shadow: var(--sh-md); border-color: var(--gray-300); }
.card__icon {
  width: 46px; height: 46px; border-radius: 11px; display: grid; place-items: center;
  background: var(--navy-100); color: var(--navy-700); margin-bottom: 18px;
}
.card__icon .ico { width: 22px; height: 22px; }
.card h3 { font-size: 19px; margin-bottom: 9px; }
.card p { color: var(--gray-700); font-size: 14.5px; margin: 0; }

/* Passos do processo (sequência real → numeração faz sentido) */
.steps { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; counter-reset: step; }
.step { position: relative; padding-top: 26px; }
.step__num {
  font-family: var(--mono); font-size: 13px; color: var(--gold-500);
  border-top: 2px solid var(--gold-500); padding-top: 12px; display: inline-block; letter-spacing: .1em;
}
.step h3 { font-size: 18px; margin: 8px 0 8px; }
.step p { color: var(--gray-700); font-size: 14px; margin: 0; }

/* CTA final */
.cta-band {
  background: linear-gradient(150deg, var(--navy-800), var(--navy-900));
  color: var(--white); border-radius: 20px; padding: 56px 48px; text-align: center;
  box-shadow: var(--sh-lg);
}
.cta-band h2 { color: var(--white); font-size: clamp(26px, 3vw, 38px); }
.cta-band p { color: #B9C7DC; max-width: 560px; margin: 16px auto 30px; font-size: 17px; }

/* ============================================================
   RODAPÉ
   ============================================================ */
.footer { background: var(--navy-900); color: #9FB1CC; padding: 48px 0 36px; }
.footer__inner { max-width: var(--maxw); margin: 0 auto; padding: 0 28px; display: flex; justify-content: space-between; gap: 24px; flex-wrap: wrap; align-items: center; }
.footer a { color: #C3D0E2; }
.footer a:hover { color: var(--gold-400); }
.footer__legal { font-size: 12.5px; color: #6F84A3; max-width: 560px; line-height: 1.6; }

/* ============================================================
   FORMULÁRIO
   ============================================================ */
.form-shell { max-width: 880px; margin: 0 auto; padding: 40px 28px 80px; }

.lgpd {
  background: var(--navy-100); border: 1px solid var(--navy-100);
  border-left: 4px solid var(--gold-500); border-radius: var(--radius-sm);
  padding: 22px 24px; margin-bottom: 26px;
}
.lgpd h4 { font-family: var(--sans); font-size: 14px; text-transform: uppercase; letter-spacing: .08em; color: var(--navy-700); margin-bottom: 8px; }
.lgpd p { font-size: 14px; color: var(--gray-700); margin: 0; }

/* Barra de progresso */
.progress { position: sticky; top: 73px; z-index: 30; background: var(--paper); padding: 18px 0 14px; }
.progress__bar { height: 8px; background: var(--gray-200); border-radius: 99px; overflow: hidden; }
.progress__fill { height: 100%; width: 12.5%; background: linear-gradient(90deg, var(--navy-600), var(--gold-500)); border-radius: 99px; transition: width .4s cubic-bezier(.4,0,.2,1); }
.progress__meta { display: flex; justify-content: space-between; align-items: baseline; margin-top: 10px; }
.progress__step { font-size: 13.5px; color: var(--gray-500); }
.progress__step b { color: var(--navy-700); }
.progress__pct { font-family: var(--mono); font-size: 13px; color: var(--gold-500); }

/* Blocos / fieldsets */
.fblock { display: none; animation: fade .35s ease; }
.fblock.is-active { display: block; }
@keyframes fade { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }

.fblock__head { margin-bottom: 26px; }
.fblock__tag { font-family: var(--mono); font-size: 12px; color: var(--gold-500); letter-spacing: .14em; text-transform: uppercase; }
.fblock__head h2 { font-size: 27px; margin: 8px 0 6px; }
.fblock__head p { color: var(--gray-500); font-size: 15px; margin: 0; }

.field { margin-bottom: 22px; }
.field > label { display: block; font-size: 15px; font-weight: 600; color: var(--navy-800); margin-bottom: 9px; }
.field .hint { font-weight: 400; color: var(--gray-500); font-size: 13.5px; display: block; margin-top: -4px; margin-bottom: 9px; }

.input, .textarea, select.input {
  width: 100%; padding: 13px 15px; font-size: 15px; font-family: inherit; color: var(--ink);
  background: var(--white); border: 1.5px solid var(--gray-300); border-radius: 10px;
  transition: border-color .18s, box-shadow .18s;
}
.textarea { min-height: 96px; resize: vertical; line-height: 1.55; }
.input:focus, .textarea:focus, select.input:focus {
  outline: none; border-color: var(--navy-500); box-shadow: 0 0 0 4px rgba(44,90,146,0.12);
}

/* Caixas de opção (checkbox / radio) */
.options { display: flex; flex-wrap: wrap; gap: 10px; }
.opt {
  position: relative; display: inline-flex; align-items: center; gap: 9px;
  padding: 10px 15px; border: 1.5px solid var(--gray-300); border-radius: 99px;
  font-size: 14px; color: var(--gray-700); background: var(--white);
  transition: all .15s; user-select: none; cursor: pointer;
}
.opt:hover { border-color: var(--navy-400, var(--navy-500)); }
.opt input { position: absolute; opacity: 0; pointer-events: none; }
.opt__dot { width: 16px; height: 16px; border-radius: 50%; border: 1.5px solid var(--gray-400); display: inline-grid; place-items: center; flex-shrink: 0; }
.opt--check .opt__dot { border-radius: 5px; }
.opt input:checked ~ .opt__dot { border-color: var(--navy-700); background: var(--navy-700); }
.opt input:checked ~ .opt__dot::after { content: ""; width: 7px; height: 7px; border-radius: 50%; background: var(--white); }
.opt--check input:checked ~ .opt__dot::after { width: 9px; height: 5px; border-radius: 0; background: transparent; border-left: 2px solid #fff; border-bottom: 2px solid #fff; transform: rotate(-45deg) translateY(-1px); }
.opt:has(input:checked) { border-color: var(--navy-700); background: var(--navy-100); color: var(--navy-800); font-weight: 600; }

/* Escala 0–10 */
.scale { }
.scale__row { display: flex; gap: 6px; flex-wrap: wrap; }
.scale__btn {
  width: 42px; height: 42px; border-radius: 9px; border: 1.5px solid var(--gray-300);
  background: var(--white); color: var(--gray-700); font-weight: 600; font-size: 15px;
  display: grid; place-items: center; transition: all .14s;
}
.scale__btn:hover { border-color: var(--navy-500); }
.scale__btn.is-on { background: var(--navy-700); color: #fff; border-color: var(--navy-700); }
.scale__ends { display: flex; justify-content: space-between; font-size: 12px; color: var(--gray-400); margin-top: 7px; }

/* Navegação do form */
.form-nav { display: flex; justify-content: space-between; gap: 14px; margin-top: 30px; padding-top: 24px; border-top: 1px solid var(--gray-200); }
.form-error { color: var(--danger); font-size: 13.5px; margin-top: 10px; display: none; }
.form-error.is-on { display: block; }

.consent {
  display: flex; gap: 12px; align-items: flex-start; padding: 18px;
  border: 1.5px solid var(--gray-300); border-radius: 10px; background: var(--gray-100); margin-bottom: 6px;
}
.consent input { margin-top: 3px; width: 18px; height: 18px; accent-color: var(--navy-700); flex-shrink: 0; }
.consent label { font-size: 14px; color: var(--gray-700); }

/* Tela de conclusão */
.done { text-align: center; padding: 60px 20px; display: none; }
.done.is-on { display: block; }
.done__ring { width: 84px; height: 84px; margin: 0 auto 22px; border-radius: 50%; background: var(--ok-bg); color: var(--ok); display: grid; place-items: center; }
.done h2 { font-size: 30px; }
.done p { color: var(--gray-700); max-width: 460px; margin: 12px auto 28px; }
.done__actions { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }

/* ============================================================
   DASHBOARD
   ============================================================ */
.page-head { background: linear-gradient(160deg, var(--navy-900), var(--navy-800)); color: #fff; padding: 46px 0 40px; }
.page-head__inner { max-width: var(--maxw); margin: 0 auto; padding: 0 28px; display: flex; justify-content: space-between; align-items: flex-end; gap: 20px; flex-wrap: wrap; }
.page-head h1 { color: #fff; font-size: 34px; }
.page-head p { color: #B9C7DC; margin: 8px 0 0; font-size: 15.5px; }
.page-head__actions { display: flex; gap: 12px; flex-wrap: wrap; }

.respbar { background: var(--white); border-bottom: 1px solid var(--gray-200); }
.respbar__inner { max-width: var(--maxw); margin: 0 auto; padding: 16px 28px; display: flex; align-items: center; gap: 16px; flex-wrap: wrap; }
.respbar label { font-size: 13.5px; color: var(--gray-500); font-weight: 600; }
.respbar select { min-width: 280px; }

.dash { max-width: var(--maxw); margin: 0 auto; padding: 36px 28px 80px; }

.kpis { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; margin-bottom: 28px; }
.kpi { background: var(--white); border: 1px solid var(--gray-200); border-radius: var(--radius); padding: 22px; box-shadow: var(--sh-sm); }
.kpi__lbl { font-size: 12.5px; color: var(--gray-500); text-transform: uppercase; letter-spacing: .05em; font-weight: 600; }
.kpi__val { font-family: var(--display); font-size: 34px; color: var(--navy-800); font-weight: 600; margin-top: 6px; line-height: 1; }
.kpi__val small { font-size: 16px; color: var(--gray-400); font-family: var(--sans); }
.kpi__foot { font-size: 12.5px; margin-top: 10px; display: inline-flex; align-items: center; gap: 6px; padding: 3px 9px; border-radius: 99px; font-weight: 600; }
.tag-ok { background: var(--ok-bg); color: var(--ok); }
.tag-warn { background: var(--warn-bg); color: var(--warn); }
.tag-danger { background: var(--danger-bg); color: var(--danger); }
.tag-neutral { background: var(--gray-100); color: var(--gray-500); }

/* Score panel */
.scorepanel { display: grid; grid-template-columns: 320px 1fr; gap: 24px; margin-bottom: 28px; }
.scorecard { background: linear-gradient(155deg, var(--navy-800), var(--navy-900)); color: #fff; border-radius: var(--radius); padding: 28px; text-align: center; box-shadow: var(--sh-md); }
.scorecard h3 { color: #C3D0E2; font-family: var(--sans); font-size: 13px; text-transform: uppercase; letter-spacing: .08em; font-weight: 600; }
.scorecard__gauge { margin: 12px auto 14px; }
.scorecard__band { display: inline-block; padding: 6px 16px; border-radius: 99px; font-weight: 600; font-size: 14px; background: rgba(201,162,75,.16); color: var(--gold-400); border: 1px solid rgba(201,162,75,.3); }

.panel { background: var(--white); border: 1px solid var(--gray-200); border-radius: var(--radius); padding: 24px; box-shadow: var(--sh-sm); }
.panel__title { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
.panel__title h3 { font-size: 18px; }
.panel__title .badge { font-family: var(--mono); font-size: 11px; color: var(--gray-500); }

.pillars { display: grid; gap: 16px; }
.pillar { display: grid; grid-template-columns: 130px 1fr 48px; align-items: center; gap: 14px; }
.pillar__name { font-size: 14px; font-weight: 600; color: var(--navy-800); }
.pillar__track { height: 10px; background: var(--gray-200); border-radius: 99px; overflow: hidden; }
.pillar__fill { height: 100%; border-radius: 99px; background: linear-gradient(90deg, var(--navy-600), var(--gold-500)); transition: width .9s cubic-bezier(.4,0,.2,1); }
.pillar__val { font-family: var(--mono); font-size: 14px; color: var(--navy-700); text-align: right; }

.charts { display: grid; grid-template-columns: repeat(2, 1fr); gap: 22px; margin-top: 28px; }
.chartcard { background: var(--white); border: 1px solid var(--gray-200); border-radius: var(--radius); padding: 22px; box-shadow: var(--sh-sm); }
.chartcard h3 { font-size: 16px; margin-bottom: 4px; }
.chartcard p { font-size: 13px; color: var(--gray-500); margin: 0 0 16px; }
.chartcard__canvas { position: relative; height: 280px; }

.empty { text-align: center; padding: 80px 20px; color: var(--gray-500); }
.empty h2 { color: var(--navy-700); margin-bottom: 10px; }

/* ============================================================
   RELATÓRIO
   ============================================================ */
.report { max-width: 920px; margin: 0 auto; padding: 40px 28px 90px; }
.report__doc { background: var(--white); border: 1px solid var(--gray-200); border-radius: var(--radius); box-shadow: var(--sh-md); overflow: hidden; }
.report__masthead { background: linear-gradient(155deg, var(--navy-800), var(--navy-900)); color: #fff; padding: 40px 44px; display: flex; justify-content: space-between; align-items: flex-start; gap: 20px; flex-wrap: wrap; }
.report__masthead h1 { color: #fff; font-size: 30px; }
.report__masthead p { color: #B9C7DC; margin: 8px 0 0; font-size: 14.5px; }
.report__seal { text-align: right; }
.report__score-big { font-family: var(--display); font-size: 54px; color: var(--gold-400); font-weight: 600; line-height: 1; }
.report__score-lbl { font-size: 12px; color: #9FB1CC; text-transform: uppercase; letter-spacing: .08em; }

.report__body { padding: 40px 44px; }
.rsection { padding: 26px 0; border-top: 1px solid var(--gray-200); }
.rsection:first-child { border-top: 0; padding-top: 6px; }
.rsection__tag { font-family: var(--mono); font-size: 12px; color: var(--gold-500); letter-spacing: .12em; text-transform: uppercase; }
.rsection h2 { font-size: 22px; margin: 6px 0 14px; }
.rsection p { color: var(--gray-700); font-size: 15.5px; line-height: 1.7; }
.rsection ul { margin: 4px 0 0; padding: 0; list-style: none; }
.rsection li { position: relative; padding: 9px 0 9px 28px; border-bottom: 1px dashed var(--gray-200); font-size: 15px; color: var(--gray-700); }
.rsection li:last-child { border-bottom: 0; }
.rsection li::before { content: ""; position: absolute; left: 4px; top: 17px; width: 8px; height: 8px; border-radius: 2px; background: var(--gold-500); }
.rsection li.neg::before { background: var(--danger); }
.rsection li.pos::before { background: var(--ok); }

.roadmap { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
.rmcol { background: var(--gray-100); border: 1px solid var(--gray-200); border-radius: var(--radius-sm); padding: 22px; }
.rmcol h3 { font-size: 16px; margin-bottom: 14px; display: flex; align-items: center; gap: 9px; }
.rmcol h3 .pill { font-family: var(--mono); font-size: 11px; background: var(--navy-700); color: #fff; padding: 3px 9px; border-radius: 99px; }
.rmstep { padding: 10px 0; border-bottom: 1px solid var(--gray-200); font-size: 14px; color: var(--gray-700); }
.rmstep:last-child { border-bottom: 0; }
.rmstep b { color: var(--navy-800); display: block; font-size: 13.5px; }

/* ============================================================
   UTIL & RESPONSIVO
   ============================================================ */
.print-only { display: none; }
@media print {
  .nav, .footer, .report__actions, .no-print { display: none !important; }
  body { background: #fff; }
  .report__doc { box-shadow: none; border: 0; }
}

@media (max-width: 980px) {
  .hero__layout { grid-template-columns: 1fr; gap: 40px; }
  .grid-3, .steps { grid-template-columns: repeat(2, 1fr); }
  .charts { grid-template-columns: 1fr; }
  .scorepanel { grid-template-columns: 1fr; }
  .kpis { grid-template-columns: repeat(2, 1fr); }
  .stripe__inner { grid-template-columns: repeat(2, 1fr); gap: 18px; }
}
@media (max-width: 720px) {
  .container { padding: 0 20px; }
  .nav__links { display: none; }
  .nav__links.is-open { display: flex; position: absolute; top: 72px; left: 0; right: 0; flex-direction: column; background: var(--white); padding: 18px 24px; border-bottom: 1px solid var(--gray-200); gap: 16px; }
  .nav__toggle { display: block; }
  .grid-3, .grid-2, .steps, .roadmap { grid-template-columns: 1fr; }
  .section { padding: 60px 0; }
  .page-head__inner, .report__masthead { flex-direction: column; align-items: flex-start; }
  .report__body { padding: 28px 22px; }
  .report__masthead { padding: 28px 22px; }
